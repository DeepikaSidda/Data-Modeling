  "ModelName": "VirtualWaitingRoom",
  "ModelMetadata": {
    "Author": "Kiro",
    "DateCreated": "2024-01-01",
    "DateLastModified": "2024-01-01",
    "Description": "Single-table DynamoDB model for a Virtual Waiting Room. Absorbs a 10M-arrival burst via write sharding on the partition key, enforces exactly-once admission with a dedupe guard, promotes batches bounded by an atomic capacity counter, and serves low-latency status. Item types: queue entry, fan dedupe guard, sharded admit counter, capacity counter, event config. No LSIs are used (see design document for rationale); two GSIs serve all cross-shard/global access patterns. Shard_Count=4000 is the production sizing for a 10M/10s burst (keeps each WaitingIndex GSI partition ~250 WCU/s, well under the 1,000 WCU/s ceiling); see Scalability and Cost Analysis in the design document.",
    "AWSService": "Amazon DynamoDB",
    "Version": "3.0"
  },
